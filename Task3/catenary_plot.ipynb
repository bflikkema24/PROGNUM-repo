   "source": [
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "x = range(\n",
    "    -5, 6)\n",
    "\n",
    "catenary = np.cosh(x)\n",
    "plt.plot(x, catenary, marker = 'o', color = 'red', label = \"cosh(x)\")\n",
    "plt.title(\"Catenary\")\n",
    "plt.xlabel(\"x\")\n",
    "plt.ylabel(\"cosh(x)\")\n",
    "plt.grid()\n",
    "plt.legend()\n",
    "plt.show()\n",
    "X = np.arange(-5,6)\n"
   ]
  }
